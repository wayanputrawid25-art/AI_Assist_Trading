# =============================================================================
# ForexOS - Root Environment Variables
# =============================================================================
# This file contains SHARED variables used by multiple components.
# Component-specific variables are in their respective .env.example files.
#
# Copy this file to .env and fill in the values.
# DO NOT commit .env files to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# NODE ENVIRONMENT (All)
# -----------------------------------------------------------------------------
NODE_ENV=development

# -----------------------------------------------------------------------------
# DATABASE (Shared: API + Robot)
# -----------------------------------------------------------------------------
# Neon PostgreSQL Connection String
# Get this from your Neon console: https://neon.tech
DATABASE_URL=postgresql://user:password@host.neon.tech/dbname?sslmode=require
